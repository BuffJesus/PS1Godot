; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PS1Godot"
config/description="PlayStation 1 game authoring in Godot."
run/main_scene="res://demo/demo.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=320
window/size/viewport_height=240
window/size/window_width_override=1280
window/size/window_height_override=960
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="PS1Godot"

[editor_plugins]

enabled=PackedStringArray("res://addons/ps1godot/plugin.cfg")

[importer_defaults]

wav={
"compress/mode": 0
}

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/default_filters/use_nearest_mipmap_filter=true
environment/defaults/default_clear_color=Color(0.18, 0.18, 0.24, 1)
