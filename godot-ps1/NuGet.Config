<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet.Config for PS1Godot.

  Godot .NET dev builds (here: 4.7.0-dev.5) are NOT published to nuget.org.
  The SDK and runtime packages live inside the Godot install at
  GodotSharp/Tools/nupkgs/. Restoring from Godot itself works because Godot
  injects that path; restoring from Rider/CLI does not, so we add it here.

  Set the GODOT_NUPKGS environment variable to the absolute path of your
  GodotSharp/Tools/nupkgs/ directory. Example:
    setx GODOT_NUPKGS "C:\tools\Godot\GodotSharp\Tools\nupkgs"
  Close and re-open terminals / Rider after setting.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="godot-local" value="%GODOT_NUPKGS%" />
  </packageSources>
</configuration>
