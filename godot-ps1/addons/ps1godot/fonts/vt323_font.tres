[gd_resource type="Resource" script_class="PS1UIFontAsset" load_steps=3 format=3]

; Bundled demo font for the PS1 UI pipeline. OFL-licensed (see OFL.txt),
; chosen because it's a proportional pixel-style face that reads cleanly
; at 10–16 px on the PSX. Drop it onto a PS1UIElement's Font slot and run
; Tools → "PS1Godot: Generate bitmap for selected PS1UIFontAsset" to
; populate GlyphWidth / GlyphHeight / Bitmap / AdvanceWidths on first use
; (those fields are persisted back into this .tres by the generator).

