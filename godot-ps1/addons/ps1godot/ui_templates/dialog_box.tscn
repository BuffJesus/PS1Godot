; Bottom-of-screen dialog box. Stack: Background → Body text → optional
; NameTag above the box. Canvas name is "dialog" to match the existing
; convention; Residency=1 (MenuOnly) keeps its VRAM out of the gameplay
; resident set. Make Local after instantiating to customize.

[node name="DialogBox" type="Node"]
script = ExtResource("1_canvas")
CanvasName = "dialog"
Residency = 1
VisibleOnLoad = false
