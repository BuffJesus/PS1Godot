[gd_resource type="ShaderMaterial" format=3]

[ext_resource type="Shader" uid="uid://lnrxmrercuvn" path="res://addons/ps1godot/shaders/ps1.gdshader" id="1"]

; Default material for PS1SkinnedMesh nodes. Same shader as ps1_default but
; snap_enabled=false: the 320x240 grid snap interacts badly with bone-driven
; vertices at editor camera distance — adjacent verts collide on the same
; grid cell and the body fragments into grey-patched triangles. World/static
; geometry keeps snap on (that's where the PSX "wobble" lives) — skinned
; characters opt out per material.

[resource]
render_priority = 0
shader = ExtResource("1")
shader_parameter/tint_color = Color(1, 1, 1, 1)
shader_parameter/snap_enabled = false
shader_parameter/snap_resolution = Vector2(320, 240)
shader_parameter/modulate_scale = 2.0
shader_parameter/fog_enabled = false
shader_parameter/fog_color = Color(0.5, 0.5, 0.6, 1)
shader_parameter/fog_near = 10.0
shader_parameter/fog_far = 50.0
shader_parameter/preview_quantize_bits = 5
shader_parameter/preview_dither_enabled = true
