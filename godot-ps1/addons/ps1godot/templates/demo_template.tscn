[gd_scene load_steps=7 format=3]

; Demo template — Empty + a floor + 2 cubes + a HUD canvas.
;
; The smallest scene that's actually visually interesting on F5.
; Use as a starting point for tutorials and capability demos. Drop
; in textures, tweak FlatColor, add walls — no template-specific
; wiring to undo.

[ext_resource type="Script" uid="uid://b8ogc8krip2k" path="res://addons/ps1godot/nodes/PS1Scene.cs" id="1_scene"]
[ext_resource type="Script" uid="uid://cfdlp12g2rtct" path="res://addons/ps1godot/nodes/PS1Player.cs" id="2_player"]
[ext_resource type="Script" uid="uid://bp3inh2eiwm3o" path="res://addons/ps1godot/nodes/PS1Camera.cs" id="3_camera"]
[ext_resource type="Script" uid="uid://dng0iofdw3dk7" path="res://addons/ps1godot/nodes/PS1MeshInstance.cs" id="4_mesh"]
[ext_resource type="Script" uid="uid://bp1p1kqop2wwy" path="res://addons/ps1godot/nodes/PS1UICanvas.cs" id="5_canvas"]
[ext_resource type="Script" uid="uid://c01mt2tth0oll" path="res://addons/ps1godot/nodes/PS1UIElement.cs" id="6_elem"]

[sub_resource type="BoxMesh" id="floor_mesh"]
size = Vector3(8, 0.5, 8)

[sub_resource type="BoxMesh" id="cube_mesh"]
size = Vector3(1, 1, 1)

[node name="DemoScene" type="Node3D"]
script = ExtResource("1_scene")
SceneType = 0

[node name="PS1Player" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, 2)
script = ExtResource("2_player")

[node name="MainCamera" type="Camera3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.94, 0.34, 0, -0.34, 0.94, 0, 2.5, 5)
fov = 60.0
script = ExtResource("3_camera")

[node name="Floor" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.25, 0)
mesh = SubResource("floor_mesh")
script = ExtResource("4_mesh")
BitDepth = 1
Collision = 1
FlatColor = Color(0.6, 0.6, 0.6, 1)

[node name="RedCube" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -1.5, 0.5, -1)
mesh = SubResource("cube_mesh")
script = ExtResource("4_mesh")
BitDepth = 1
Collision = 1
FlatColor = Color(0.8, 0.3, 0.3, 1)

[node name="BlueCube" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 1.5, 0.5, 0)
mesh = SubResource("cube_mesh")
script = ExtResource("4_mesh")
BitDepth = 1
Collision = 1
FlatColor = Color(0.3, 0.5, 0.8, 1)

[node name="hud" type="Node" parent="."]
script = ExtResource("5_canvas")
CanvasName = "hud"
SortOrder = 10

[node name="HudLabel" type="Node" parent="hud"]
script = ExtResource("6_elem")
ElementName = "hint"
Type = 2
X = 8
Y = 8
Width = 304
Height = 16
Color = Color(0.95, 0.95, 0.95, 1)
Text = "Demo scene — duplicate this template to start"
