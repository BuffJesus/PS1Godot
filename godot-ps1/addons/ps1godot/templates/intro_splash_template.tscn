[ext_resource type="Script" uid="uid://bmwv0x052a03l" path="res://addons/ps1godot/nodes/PS1AnimationTrack.cs" id="6_tr"]
[ext_resource type="Script" uid="uid://bg1ih72kp4c3g" path="res://addons/ps1godot/nodes/PS1AnimationKeyframe.cs" id="7_kf"]
[ext_resource type="Script" path="res://addons/ps1godot/nodes/PS1AudioEvent.cs" id="8_ae"]
