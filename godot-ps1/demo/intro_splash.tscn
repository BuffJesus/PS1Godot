; One-shot sequence. LoopStartBeat=-1 → sequencer stops after the
; final event instead of looping back to tick 0. Total playback
; length: 13.17s (MIDI events end at tick 7584 @ 90 BPM, 384 ticks/
; quarter) + 0.5s (last inst_lead sample decay) ≈ 13.67s. Paired with
; the cutscene's 420-frame (14s) length so Scene.Load(1) can't fire
; before the chime finishes decaying.
[sub_resource type="Resource" id="Seq_splash"]
script = ExtResource("18_mseq")
MidiFile = "res://demo/audio/music/ps1_startup.mid"
SequenceName = "ps1_startup"
LoopStartBeat = -1
Channels = Array[ExtResource("17_mchan")]([SubResource("Chan_lead"), SubResource("Chan_bass_a"), SubResource("Chan_bass_b"), SubResource("Chan_triangle_a"), SubResource("Chan_triangle_b"), SubResource("Chan_triangle_c"), SubResource("Chan_pluck"), SubResource("Chan_finalchime")])
metadata/_custom_type_script = "uid://c2oekhtvjyqlt"

; Root PS1Scene. Scene 0 on export. SubScenes = [demo, realm] so Lua
; calls map to: Scene.Load(1) -> main demo, Scene.Load(2) -> realm.
; Black fog hides the edges of the scene so the HeadSpider "floats in
; space" the way the stock PS1 boot logo floats on a black field.
[node name="IntroSplash" type="Node3D" unique_id=9100000001]
script = ExtResource("1_scene")
SceneType = 6
FogEnabled = false
FogColor = Color(0, 0, 0, 1)
FogDensity = 1
SceneLuaFile = "res://demo/scripts/intro_splash.lua"
AudioClips = Array[ExtResource("2_clip")]([SubResource("Clip_chime")])
MusicSequences = Array[ExtResource("18_mseq")]([SubResource("Seq_splash")])
SubScenes = Array[PackedScene]([ExtResource("13_demo"), ExtResource("14_realm")])

; PS1Player at origin — the splash doesn't use player movement (controls
; are disabled in intro_splash.lua), but the runtime expects a player
; spawn point and a camera rig target. Camera is driven by the cutscene's
; CameraPosition + CameraRotation tracks below.
[node name="PS1Player" type="Node3D" parent="." unique_id=9100000002]
script = ExtResource("3_player")

; HeadSpider is a PS1MeshGroup — wraps the 5-piece FBX import so the
; exporter merges Bug + FrontLegs + Head + LeftEye + RightEye into a
; SINGLE exported GameObject. The cutscene's SpiderRotTrack can then
; target "HeadSpider" with an ObjectRotation track and spin the whole
; prop as a unit (a plain MeshInstance3D auto-walk would emit five
; separate GameObjects, and rotation tracks target one at a time).
;
; Scale 0.5 + Y=1.5 keeps the body framed above the PS1 screen's
; reserved bottom text band (Y>=168). The transform lives on the group
; so the rotation track spins around the group's origin (= spider's
; feet) rather than swinging the whole mesh around world zero.
[node name="HeadSpider" type="Node3D" parent="." unique_id=9100000003]
script = ExtResource("16_meshgroup")
transform = Transform3D(0.5, 0, 0, 0, 0.5, 0, 0, 0, 0.5, 0, 1.5, 0)

; FBX instance sits at identity inside the group — all transform lives
; on the parent. Editable-children overrides wire per-submesh materials:
; body/head/legs share ps1_headspider_body.tres, eyes use
; ps1_headspider_eyes.tres.
[node name="SpiderMesh" parent="HeadSpider" unique_id=9100000004 instance=ExtResource("11_headspider")]

[editable path="HeadSpider/SpiderMesh"]

[node name="Bug" parent="HeadSpider/SpiderMesh"]
material_override = ExtResource("12_mat_body")

[node name="FrontLegs" parent="HeadSpider/SpiderMesh"]
material_override = ExtResource("12_mat_body")

[node name="Head" parent="HeadSpider/SpiderMesh"]
material_override = ExtResource("12_mat_body")

[node name="LeftEye" parent="HeadSpider/SpiderMesh"]
material_override = ExtResource("12_mat_eyes")

[node name="RightEye" parent="HeadSpider/SpiderMesh"]
material_override = ExtResource("12_mat_eyes")

; 14-second cutscene. Length is driven by the ps1_startup music
; sequence: MIDI events run ~13.17s + the 0.5s inst_lead sample decay
; on the final chime ≈ 13.67s of audible audio. TotalFrames=420 (14s @
; 30fps) guarantees Scene.Load(1) can't fire before the chime finishes.
; Music is kicked off from intro_splash.lua's onSceneCreationEnd (not
; a PS1AudioEvent, since sequenced music has its own Lua Play API).
;
; Static camera frames the HeadSpider at (0, 2.5, 4) with a 5° downward
; pitch; SpiderRotTrack spins the PS1MeshGroup a full 360° across the
; 420-frame timeline (~25.7°/sec — slow, dignified turntable pace that
; fits a 14-second boot logo).
[node name="IntroCutscene" type="Node" parent="." unique_id=9100000010]
script = ExtResource("4_cs")
CutsceneName = "intro_splash"
TotalFrames = 420

[node name="CamPosTrack" type="Node" parent="IntroCutscene" unique_id=9100000011]
script = ExtResource("5_tr")
TrackType = 0

[node name="CamPosKf0" type="Node" parent="IntroCutscene/CamPosTrack" unique_id=9100000012]
script = ExtResource("6_kf")
Frame = 0
Value = Vector3(0, 2.5, 4)

[node name="CamPosKf1" type="Node" parent="IntroCutscene/CamPosTrack" unique_id=9100000013]
script = ExtResource("6_kf")
Frame = 419
Value = Vector3(0, 2.5, 4)
Interp = 0

[node name="CamRotTrack" type="Node" parent="IntroCutscene" unique_id=9100000020]
script = ExtResource("5_tr")
TrackType = 1

[node name="CamRotKf0" type="Node" parent="IntroCutscene/CamRotTrack" unique_id=9100000021]
script = ExtResource("6_kf")
Frame = 0
Value = Vector3(5, 180, 0)

[node name="CamRotKf1" type="Node" parent="IntroCutscene/CamRotTrack" unique_id=9100000022]
script = ExtResource("6_kf")
Frame = 419
Value = Vector3(5, 180, 0)
Interp = 0

; Object rotation track — the whole point of bundling HeadSpider as a
; PS1MeshGroup. TrackType 3 = ObjectRotation; TargetObjectName must
; match the group's exported name ("HeadSpider"). Rotation sweep
; spans the entire 420-frame cutscene so the prop stays in motion
; until the Scene.Load handoff (no awkward "stops spinning then
; transitions" beat).
[node name="SpiderRotTrack" type="Node" parent="IntroCutscene" unique_id=9100000030]
script = ExtResource("5_tr")
TargetObjectName = "HeadSpider"
TrackType = 3

[node name="SpiderRotKf0" type="Node" parent="IntroCutscene/SpiderRotTrack" unique_id=9100000031]
script = ExtResource("6_kf")
Frame = 0
Value = Vector3(0, 0, 0)

[node name="SpiderRotKf1" type="Node" parent="IntroCutscene/SpiderRotTrack" unique_id=9100000032]
script = ExtResource("6_kf")
Frame = 419
Value = Vector3(0, 360, 0)

; UI — "brand" at top (studio name) + "licensed" block below (small
; legal-style text). Theme slot `Neutral` keeps both a soft grey on
; black, evoking the stock PS1 boot logo's SCEE text without copying
