[sub_resource type="Resource" id="Clip_chime"]
script = ExtResource("2_clip")
Stream = ExtResource("15_chime_stream")
ClipName = "splash_chime"
metadata/_custom_type_script = "uid://cgk0vce50p3ph"

; Music-sequencer channels for ps1_startup.mid. Source uses intra-channel
; chords: MIDI ch 1 plays dyads, ch 2 plays triads, ch 6 plays dyads.
; Our sequencer is MONO per packed voice, so a chord on one MIDI channel
; would retrigger itself and collapse to the last note (notes appearing
; "skipped"). Fix: bind the same MIDI channel multiple times — each
; duplicate binding becomes a polyphony lane, and PS1MSerializer's
; voice-stealing allocator spreads chord members across the lanes.
;
; Allocation within the 8-voice MusicSequencer::MAX_CHANNELS cap:
;   ch 0 → 1 lane (mono lead)
;   ch 1 → 2 lanes (bass dyads)
;   ch 2 → 3 lanes (triangle triads — the iconic rising arpeggio)
;   ch 4 → 1 lane (final high chime)
;   ch 6 → 1 lane (pluck ostinato; chord-collision cost is small here
;                  because the chords are dense fast dyads that
;                  function as thickening rather than harmony)
; = 8 lanes. Remaining MIDI channels (3, 5, 7–12) are exact duplicates
; of bound channels (verified via midi_binding_trace.py) — dropping
; them costs no unique content.
;
; Every lane plays the single `splash_chime` sample (inst_lead.wav);
; the pitch table handles per-note frequency shifts. BaseNoteMidi=69
; (A4) matches demo.tscn's `inst_lead` convention.
[sub_resource type="Resource" id="Chan_lead"]
script = ExtResource("17_mchan")
MidiChannel = 0
AudioClipName = "splash_chime"
BaseNoteMidi = 69
Volume = 110
metadata/_custom_type_script = "uid://3bx6n5sx7krl"

[sub_resource type="Resource" id="Chan_bass_a"]
script = ExtResource("17_mchan")
MidiChannel = 1
AudioClipName = "splash_chime"
BaseNoteMidi = 69
Volume = 95
metadata/_custom_type_script = "uid://3bx6n5sx7krl"

[sub_resource type="Resource" id="Chan_bass_b"]
script = ExtResource("17_mchan")
MidiChannel = 1
AudioClipName = "splash_chime"
BaseNoteMidi = 69
