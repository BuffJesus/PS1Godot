[sub_resource type="Resource" id="Clip_chime"]
script = ExtResource("2_clip")
Stream = ExtResource("15_chime_stream")
ClipName = "splash_chime"
metadata/_custom_type_script = "uid://cgk0vce50p3ph"

; Root PS1Scene. Scene 0 on export. SubScenes = [demo, realm] so Lua
; calls map to: Scene.Load(1) -> main demo, Scene.Load(2) -> realm.
; Black fog hides the edges of the scene so the HeadSpider "floats in
; space" the way the stock PS1 boot logo floats on a black field.
[node name="IntroSplash" type="Node3D" unique_id=9100000001]
script = ExtResource("1_scene")
SceneType = 6
FogEnabled = true
FogColor = Color(0, 0, 0, 1)
FogDensity = 30
SceneLuaFile = "res://demo/scripts/intro_splash.lua"
AudioClips = Array[ExtResource("2_clip")]([SubResource("Clip_chime")])
SubScenes = Array[PackedScene]([ExtResource("13_demo"), ExtResource("14_realm")])

; PS1Player at origin — the splash doesn't use player movement (controls
; are disabled in intro_splash.lua), but the runtime expects a player
; spawn point and a camera rig target. Camera is driven by the cutscene's
; CameraPosition + CameraRotation tracks below.
[node name="PS1Player" type="Node3D" parent="." unique_id=9100000002]
script = ExtResource("3_player")

; HeadSpider FBX instance. Rendered via SceneCollector's raw-MeshInstance3D
; auto-detect path (introduced 2026-04-21); no PS1MeshInstance wrapper
; needed. Material override points at ps1_headspider_body.tres so it
; renders with the HeadSpider.png texture on PSX. If the FBX has an
; internal eyes mesh with its own surface, author a per-surface override
; in the editor pointing at ps1_headspider_eyes.tres.
[node name="HeadSpider" parent="." unique_id=9100000003 instance=ExtResource("11_headspider")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.5, 0)
material_override = ExtResource("12_mat_body")

; 5-second orbit cutscene. Camera pulls from an establishing distance
; to a closer orbit, then back out, while the HeadSpider spins slowly
; on Y. Chime fires at frame 0 via the PS1AudioEvent child.
[node name="IntroCutscene" type="Node" parent="." unique_id=9100000010]
script = ExtResource("4_cs")
CutsceneName = "intro_splash"
TotalFrames = 150

