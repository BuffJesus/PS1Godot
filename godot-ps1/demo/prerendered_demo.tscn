[node name="Cube_B1" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.5, -13)
mesh = SubResource("cube_mesh")
script = ExtResource("4_mesh")
BitDepth = 1
Collision = 1

; ── Trigger zones ───────────────────────────────────────────────────
; Each trigger fires onTriggerEnter(triggerIndex) on the linked Lua
; script. The script dispatches by index — TriggerA = index 0,
; TriggerB = index 1 (assigned in scene-walk order). Add more
; triggers and renumber the Lua dispatch if needed.
[node name="TriggerA" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, -3.7)
script = ExtResource("10_trigger")
HalfExtents = Vector3(4, 1.5, 0.3)
ScriptFile = "res://lua/demo/prerendered_demo.lua"

[node name="TriggerB" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, -8.3)
script = ExtResource("10_trigger")
HalfExtents = Vector3(4, 1.5, 0.3)
ScriptFile = "res://lua/demo/prerendered_demo.lua"

; ── Pre-rendered backdrops ──────────────────────────────────────────
; SortOrder=9999 puts these FIRST in LIFO-inverted draw order = drawn
; LAST = behind 3D (memory pin project_psx_ui_sort_order_inverted).
; Lua toggles VisibleOnLoad-equivalent via UI.SetVisible at runtime.
[node name="background_a" type="Node" parent="."]
script = ExtResource("5_canvas")
CanvasName = "background_a"
SortOrder = 9999
VisibleOnLoad = true
Theme = ExtResource("7_theme")

[node name="bg_image" type="Node" parent="background_a"]
script = ExtResource("6_elem")
ElementName = "bg_image_a"
Type = 0
X = 32
Y = 0
Width = 256
Height = 240
Texture = ExtResource("8_bg_a")
BitDepth = 0

[node name="background_b" type="Node" parent="."]
