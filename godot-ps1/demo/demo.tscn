[node name="CamPosTrack" type="Node" parent="IntroCutscene" unique_id=1136654869]
script = ExtResource("15_tr")
TrackType = 0

; Camera positions are z>player.z (behind player) because the rotation
; track uses yaw=180° → forward = -Z world. So looking from larger Z
; toward smaller Z brings the scene into view. Final keyframe (0, 3, 11)
; matches the third-person rig (player + offset) for a seamless handoff.
[node name="CamPosKf0" type="Node" parent="IntroCutscene/CamPosTrack" unique_id=1293512181]
script = ExtResource("13_kf")
Value = Vector3(0, 12, 15)

[node name="CamPosKf1" type="Node" parent="IntroCutscene/CamPosTrack" unique_id=859689584]
script = ExtResource("13_kf")
Frame = 180
Value = Vector3(-2, 6, 6)
Interp = 4

[node name="CamPosKf2" type="Node" parent="IntroCutscene/CamPosTrack" unique_id=777955848]
script = ExtResource("13_kf")
Frame = 345
Value = Vector3(-4, 2, 1)
Interp = 4

[node name="CamPosKf3" type="Node" parent="IntroCutscene/CamPosTrack" unique_id=31898244]
script = ExtResource("13_kf")
Frame = 500
Value = Vector3(-1, 4, 6)
Interp = 4

[node name="CamPosKf4" type="Node" parent="IntroCutscene/CamPosTrack" unique_id=560384909]
script = ExtResource("13_kf")
Frame = 599
Value = Vector3(0, 3, 11)
Interp = 4

[node name="CamRotTrack" type="Node" parent="IntroCutscene" unique_id=711669043]
script = ExtResource("15_tr")
TrackType = 1

; Derived from psyqo source (verified against soft-math.cpp +
; camera.cpp + renderer.cpp::worldToCamera):
;   * Camera matrix M = rotY * rotX * rotZ; vs[i] is column i.
;   * Camera world-forward = M.column2.
;   * Encoder negates Godot X & Y angles (SceneCollector
;     EncodeKeyframeValue:836-839).
;   * For yaw=180° the matrix flips the X-rotation's Y component sign,
;     so POSITIVE Godot pitch = camera tilts DOWN toward scene (the
;     opposite of what intuition would say with yaw=0).
;
; Yaw is 180° on every keyframe — same as the player rig's
; playerRotationY=1.0_pi — so the handoff at frame 599 has zero
; rotation discontinuity. Pitch eases from steep down (45°) at the
; overhead establishing shot to level (0°) at the handoff.
[node name="CamRotKf0" type="Node" parent="IntroCutscene/CamRotTrack" unique_id=1515879523]
script = ExtResource("13_kf")
Value = Vector3(45, 180, 0)

[node name="CamRotKf1" type="Node" parent="IntroCutscene/CamRotTrack" unique_id=1661118081]
script = ExtResource("13_kf")
Frame = 180
Value = Vector3(30, 180, 0)
Interp = 4

[node name="CamRotKf2" type="Node" parent="IntroCutscene/CamRotTrack" unique_id=320274732]
script = ExtResource("13_kf")
Frame = 345
Value = Vector3(15, 180, 0)
Interp = 4

[node name="CamRotKf3" type="Node" parent="IntroCutscene/CamRotTrack" unique_id=624521851]
script = ExtResource("13_kf")
Frame = 500
Value = Vector3(10, 180, 0)
Interp = 4

[node name="CamRotKf4" type="Node" parent="IntroCutscene/CamRotTrack" unique_id=1322462890]
script = ExtResource("13_kf")
Frame = 599
Value = Vector3(0, 180, 0)
Interp = 4

