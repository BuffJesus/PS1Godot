; Placeholder avatar — person-shaped box textured with the same
; NonOverlapping image the main demo's Player mesh uses. Not the full
; humanoid mesh yet because that mesh lives as a sub_resource inside
; demo.tscn and Godot doesn't let you reference another scene's
; sub_resources directly; externalising it to a .tres is a follow-up
; slice. Width/depth match the humanoid's silhouette (~0.6 × 0.3),
; height is 1.7 m to match playerHeight.
[sub_resource type="BoxMesh" id="BoxMesh_avatar"]
size = Vector3(0.6, 1.7, 0.3)

[sub_resource type="StandardMaterial3D" id="mat_avatar"]
resource_name = "Avatar_Humanoid"
albedo_texture = ExtResource("10_humanoid_tex")
texture_filter = 0

