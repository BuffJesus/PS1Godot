; Realm's own Dialog UI canvas. Without this the realm_cube_dialog
; script's UI.FindCanvas("dialog") returns -1 and the dialog never
; shows (symptom: "Triangle does nothing on the cube"). Same layout +
; theme slots as the main demo's dialog box.
[node name="Dialog" type="Node" parent="." unique_id=2020100010]
script = ExtResource("11_uican")
CanvasName = "dialog"
Residency = 1
VisibleOnLoad = false
SortOrder = 20
Theme = ExtResource("13_theme")

[node name="Background" type="Node" parent="Dialog" unique_id=2020100011]
script = ExtResource("12_uiel")
ElementName = "bg"
Type = 1
X = 40
Y = 160
Width = 240
Height = 64
Color = Color(0, 0, 0.4, 1)
ThemeSlot = 3

[node name="Body" type="Node" parent="Dialog" unique_id=2020100012]
script = ExtResource("12_uiel")
ElementName = "body"
X = 48
Y = 172
Width = 224
Height = 48
ThemeSlot = 1
Text = "Hello from the realm!"

[node name="ReturnTrigger" type="Node3D" parent="." unique_id=446014279]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, 8)
script = ExtResource("4_trigger")
HalfExtents = Vector3(3, 2, 1)
ScriptFile = "res://demo/scripts/teleport_back.lua"

; Player spawn + third-person rig. Without this block the runtime has
; no player so interactions (Triangle on cube) silently fail and the
; camera has nothing to follow — both symptoms reported before this
; commit. CameraRig child supplies the third-person offset
; (player-local 0, 1, 3 = 1m up + 3m behind after the yaw rig rotates
; it). Avatar MeshInstance3D is a child so the v21 auto-avatar path
; picks it up and tracks it to player position each frame.
[node name="PS1Player" type="Node3D" parent="." unique_id=2020100001]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 2, 6)
script = ExtResource("8_player")

[node name="CameraRig" type="Camera3D" parent="PS1Player" unique_id=2020100002]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, 3)

[node name="Avatar" type="MeshInstance3D" parent="PS1Player" unique_id=2020100003]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.85, 0)
material_override = SubResource("mat_avatar")
mesh = SubResource("BoxMesh_avatar")
script = ExtResource("2_mesh")
