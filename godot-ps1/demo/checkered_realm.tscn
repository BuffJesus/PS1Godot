; Player spawn + third-person rig. Without this block the runtime has
; no player so interactions (Triangle on cube) silently fail and the
; camera has nothing to follow — both symptoms reported before this
; commit. CameraRig child supplies the third-person offset
; (player-local 0, 1, 3 = 1m up + 3m behind after the yaw rig rotates
; it). Avatar MeshInstance3D is a child so the v21 auto-avatar path
; picks it up and tracks it to player position each frame.
[node name="PS1Player" type="Node3D" parent="." unique_id=2020100001]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 2, 6)
script = ExtResource("8_player")

[node name="CameraRig" type="Camera3D" parent="PS1Player" unique_id=2020100002]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, 3)

[node name="Avatar" type="MeshInstance3D" parent="PS1Player" unique_id=2020100003]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.85, 0)
material_override = SubResource("mat_avatar")
mesh = SubResource("BoxMesh_avatar")
script = ExtResource("2_mesh")
